        "required": [
          "symbol",
          "window_days",
          "overall_daily_stddev_pct",
          "worst_window"
        ],
        "title": "VolatilityReport",
        "type": "object"
      },
      "VolatilityWindow": {
        "description": "A dated window with its daily-return standard deviation.",
        "properties": {
          "daily_stddev_pct": {
            "title": "Daily Stddev Pct",
            "type": "number"
          },
          "end_date": {
            "title": "End Date",
            "type": "string"
          },
          "start_date": {
            "title": "Start Date",
            "type": "string"
          }
        },
        "required": [
          "start_date",
          "end_date",
          "daily_stddev_pct"
        ],
        "title": "VolatilityWindow",
        "type": "object"
      }
    }
  },
  "info": {
    "description": "Personal trading toolkit: prices, S&P 500 membership, and analysis over a Postgres document store. The kt CLI is a twin of this API.",
    "title": "kytrade",
    "version": "4.0.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/_live": {
      "get": {
        "description": "Liveness probe.",
        "operationId": "live__live_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": {
                    "type": "string"
                  },
                  "title": "Response Live  Live Get",
                  "type": "object"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Live"
      }
    },
    "/analysis/compare": {
      "get": {
        "description": "Window returns for several symbols, best first.",
        "operationId": "compare_analysis_compare_get",
        "parameters": [
          {
            "in": "query",
            "name": "symbols",
            "required": true,
            "schema": {
              "items": {
                "type": "string"
              },
              "minItems": 2,
              "title": "Symbols",
              "type": "array"
            }
          },
          {
            "in": "query",
            "name": "days",
            "required": false,
            "schema": {
              "default": 365,
              "exclusiveMinimum": 0,
              "title": "Days",
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Comparison"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Compare"
      }
    },
    "/analysis/movers": {
      "get": {
        "description": "Best and worst window returns across the stored universe.",
        "operationId": "movers_analysis_movers_get",
        "parameters": [
          {
            "in": "query",
            "name": "days",
            "required": false,
            "schema": {
              "default": 30,
              "exclusiveMinimum": 0,
              "title": "Days",
              "type": "integer"
            }
          },
          {
            "in": "query",
            "name": "top",
            "required": false,
            "schema": {
              "default": 10,
              "exclusiveMinimum": 0,
              "title": "Top",
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Movers"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Movers"
      }
    },
    "/analysis/near-extreme": {
      "get": {
        "description": "Symbols trading within threshold of their lookback high or low.",
        "operationId": "near_extreme_analysis_near_extreme_get",
        "parameters": [
          {
            "in": "query",
            "name": "kind",
            "required": false,
            "schema": {
              "default": "high",
              "enum": [
                "high",
                "low"
              ],
              "title": "Kind",
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "threshold_pct",
            "required": false,
            "schema": {
              "default": 5.0,
              "minimum": 0,
              "title": "Threshold Pct",
              "type": "number"
            }
          },
          {
            "in": "query",
            "name": "lookback_days",
            "required": false,
            "schema": {
              "default": 365,
              "exclusiveMinimum": 0,
              "title": "Lookback Days",
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ScreenerReport"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Near Extreme"
      }
    },
    "/analysis/performance/{symbol}": {
      "get": {
        "description": "Window performance for one symbol.",
        "operationId": "performance_analysis_performance__symbol__get",
        "parameters": [
          {
            "in": "path",
            "name": "symbol",
            "required": true,
            "schema": {
              "title": "Symbol",
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "days",
            "required": false,
            "schema": {
              "default": 90,
              "exclusiveMinimum": 0,
              "title": "Days",
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Performance"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Performance"
      }
    },
    "/analysis/sectors": {
      "get": {
        "description": "Average member return per sector, best first.",
        "operationId": "sectors_analysis_sectors_get",
        "parameters": [
          {
            "in": "query",
            "name": "days",
            "required": false,
            "schema": {
              "default": 90,
              "exclusiveMinimum": 0,
              "title": "Days",
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SectorReport"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Sectors"
      }
    },
    "/analysis/volatility/{symbol}": {
      "get": {
        "description": "Daily-return volatility and the worst rolling window.",
        "operationId": "volatility_analysis_volatility__symbol__get",
        "parameters": [
          {
            "in": "path",
            "name": "symbol",
            "required": true,
            "schema": {
              "title": "Symbol",
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "window_days",
            "required": false,
            "schema": {
              "default": 21,
              "exclusiveMinimum": 1,
              "title": "Window Days",
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VolatilityReport"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Volatility"
      }
    },
    "/bootstrap": {
      "post": {
        "description": "Prepare the toolkit: secrets, tables, and S&P 500 membership.",
        "operationId": "bootstrap_bootstrap_post",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BootstrapReport"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Bootstrap"
      }
    },
    "/data/prices/{symbol}": {
      "get": {
        "description": "Stored daily prices for a symbol, oldest first.",
        "operationId": "prices_data_prices__symbol__get",
        "parameters": [
          {
            "in": "path",
            "name": "symbol",
            "required": true,
            "schema": {
              "title": "Symbol",
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "tail",
            "required": false,
            "schema": {
              "default": 0,
              "minimum": 0,
              "title": "Tail",
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DailyPrices"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
