        "type": "object"
      },
      "MembershipLogEntry": {
        "description": "One dated membership change.",
        "properties": {
          "added": {
            "items": {
              "type": "string"
            },
            "title": "Added",
            "type": "array"
          },
          "date": {
            "title": "Date",
            "type": "string"
          },
          "removed": {
            "items": {
              "type": "string"
            },
            "title": "Removed",
            "type": "array"
          }
        },
        "required": [
          "date",
          "added",
          "removed"
        ],
        "title": "MembershipLogEntry",
        "type": "object"
      },
      "Movers": {
        "description": "Best and worst window returns across the known universe.",
        "properties": {
          "days": {
            "title": "Days",
            "type": "integer"
          },
          "gainers": {
            "items": {
              "$ref": "#/components/schemas/ComparisonEntry"
            },
            "title": "Gainers",
            "type": "array"
          },
          "losers": {
            "items": {
              "$ref": "#/components/schemas/ComparisonEntry"
            },
            "title": "Losers",
            "type": "array"
          },
          "universe": {
            "title": "Universe",
            "type": "integer"
          }
        },
        "required": [
          "days",
          "gainers",
          "losers",
          "universe"
        ],
        "title": "Movers",
        "type": "object"
      },
      "Performance": {
        "description": "Window performance for one symbol.",
        "properties": {
          "avg_volume": {
            "title": "Avg Volume",
            "type": "integer"
          },
          "days": {
            "title": "Days",
            "type": "integer"
          },
          "end_close": {
            "title": "End Close",
            "type": "number"
          },
          "end_date": {
            "title": "End Date",
            "type": "string"
          },
          "high": {
            "title": "High",
            "type": "number"
          },
          "low": {
            "title": "Low",
            "type": "number"
          },
          "return_pct": {
            "title": "Return Pct",
            "type": "number"
          },
          "start_close": {
            "title": "Start Close",
            "type": "number"
          },
          "start_date": {
            "title": "Start Date",
            "type": "string"
          },
          "symbol": {
            "title": "Symbol",
            "type": "string"
          }
        },
        "required": [
          "symbol",
          "days",
          "start_date",
          "end_date",
          "start_close",
          "end_close",
          "return_pct",
          "high",
          "low",
          "avg_volume"
        ],
        "title": "Performance",
        "type": "object"
      },
      "PullIn": {
        "properties": {
          "all_symbols": {
            "default": false,
            "title": "All Symbols",
            "type": "boolean"
          },
          "full": {
            "default": false,
            "title": "Full",
            "type": "boolean"
          },
          "symbol": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Symbol"
          }
        },
        "title": "PullIn",
        "type": "object"
      },
      "PullOut": {
        "properties": {
          "new_days": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "New Days"
          },
          "symbol": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Symbol"
          }
        },
        "required": [
          "symbol",
          "new_days"
        ],
        "title": "PullOut",
        "type": "object"
      },
      "RefreshReport": {
        "description": "Result of a staleness-aware refresh.",
        "properties": {
          "failed": {
            "items": {
              "type": "string"
            },
            "title": "Failed",
            "type": "array"
          },
          "new_days": {
            "title": "New Days",
            "type": "integer"
          },
          "pulled": {
            "title": "Pulled",
            "type": "integer"
          },
          "skipped": {
            "title": "Skipped",
            "type": "integer"
          }
        },
        "required": [
          "pulled",
          "skipped",
          "failed",
          "new_days"
        ],
        "title": "RefreshReport",
        "type": "object"
      },
      "ScreenerReport": {
        "description": "Symbols within threshold of their lookback high or low.",
        "properties": {
          "hits": {
            "items": {
              "$ref": "#/components/schemas/ExtremeHit"
            },
            "title": "Hits",
            "type": "array"
          },
          "kind": {
            "title": "Kind",
            "type": "string"
          },
          "lookback_days": {
            "title": "Lookback Days",
            "type": "integer"
          },
          "threshold_pct": {
            "title": "Threshold Pct",
            "type": "number"
          },
          "universe": {
            "title": "Universe",
            "type": "integer"
          }
        },
        "required": [
          "kind",
          "threshold_pct",
          "lookback_days",
          "hits",
          "universe"
        ],
        "title": "ScreenerReport",
        "type": "object"
      },
      "SectorPerformance": {
        "description": "Average member return for one sector.",
        "properties": {
          "return_pct": {
            "title": "Return Pct",
            "type": "number"
          },
          "sector": {
            "title": "Sector",
            "type": "string"
          },
          "symbols": {
            "title": "Symbols",
            "type": "integer"
          }
        },
        "required": [
          "sector",
          "return_pct",
          "symbols"
        ],
        "title": "SectorPerformance",
        "type": "object"
      },
      "SectorReport": {
        "description": "Sector performance over a window, best first.",
        "properties": {
          "days": {
            "title": "Days",
            "type": "integer"
          },
          "sectors": {
            "items": {
              "$ref": "#/components/schemas/SectorPerformance"
            },
            "title": "Sectors",
            "type": "array"
          }
        },
        "required": [
          "days",
          "sectors"
        ],
        "title": "SectorReport",
        "type": "object"
      },
      "Staleness": {
        "description": "How fresh the stored price data is, by symbol count.",
        "properties": {
          "never": {
            "title": "Never",
            "type": "integer"
          },
          "older": {
            "title": "Older",
            "type": "integer"
          },
          "today": {
            "title": "Today",
            "type": "integer"
          },
          "week": {
            "title": "Week",
            "type": "integer"
          }
        },
        "required": [
          "today",
          "week",
          "older",
          "never"
        ],
        "title": "Staleness",
        "type": "object"
      },
      "StatusReport": {
        "description": "Health of the toolkit.",
        "properties": {
          "db_ok": {
            "title": "Db Ok",
            "type": "boolean"
          },
          "documents": {
            "title": "Documents",
            "type": "integer"
          },
          "priced_symbols": {
            "title": "Priced Symbols",
            "type": "integer"
          },
          "staleness": {
            "$ref": "#/components/schemas/Staleness"
          },
          "symbols": {
            "title": "Symbols",
            "type": "integer"
          },
          "tables_ok": {
            "title": "Tables Ok",
            "type": "boolean"
          }
        },
        "required": [
          "db_ok",
          "tables_ok",
          "documents",
          "symbols",
          "priced_symbols",
          "staleness"
        ],
        "title": "StatusReport",
        "type": "object"
      },
      "ValidationError": {
        "properties": {
          "ctx": {
            "title": "Context",
            "type": "object"
          },
          "input": {
            "title": "Input"
          },
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "title": "Location",
            "type": "array"
          },
          "msg": {
            "title": "Message",
            "type": "string"
          },
          "type": {
            "title": "Error Type",
            "type": "string"
          }
        },
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError",
        "type": "object"
      },
      "VersionOut": {
        "properties": {
          "version": {
            "title": "Version",
            "type": "string"
          }
        },
        "required": [
          "version"
        ],
        "title": "VersionOut",
        "type": "object"
      },
      "VolatilityReport": {
        "description": "Volatility for one symbol: overall and the worst rolling window.",
        "properties": {
          "overall_daily_stddev_pct": {
            "title": "Overall Daily Stddev Pct",
            "type": "number"
          },
          "symbol": {
            "title": "Symbol",
            "type": "string"
          },
          "window_days": {
            "title": "Window Days",
            "type": "integer"
          },
          "worst_window": {
            "$ref": "#/components/schemas/VolatilityWindow"
          }
