{
  "components": {
    "schemas": {
      "BootstrapReport": {
        "description": "Result of bootstrapping the toolkit.",
        "properties": {
          "db_ok": {
            "title": "Db Ok",
            "type": "boolean"
          },
          "env_file": {
            "title": "Env File",
            "type": "string"
          },
          "password_generated": {
            "title": "Password Generated",
            "type": "boolean"
          },
          "symbols_loaded": {
            "title": "Symbols Loaded",
            "type": "integer"
          },
          "tables_created": {
            "title": "Tables Created",
            "type": "boolean"
          }
        },
        "required": [
          "env_file",
          "password_generated",
          "db_ok",
          "tables_created",
          "symbols_loaded"
        ],
        "title": "BootstrapReport",
        "type": "object"
      },
      "Comparison": {
        "description": "Window returns for several symbols, best first.",
        "properties": {
          "days": {
            "title": "Days",
            "type": "integer"
          },
          "entries": {
            "items": {
              "$ref": "#/components/schemas/ComparisonEntry"
