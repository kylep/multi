        },
        "required": [
          "days",
          "entries"
        ],
        "title": "Comparison",
        "type": "object"
      },
      "ComparisonEntry": {
        "description": "One symbol's line in a comparison.",
        "properties": {
          "end_close": {
            "title": "End Close",
            "type": "number"
          },
          "return_pct": {
            "title": "Return Pct",
            "type": "number"
          },
          "start_close": {
            "title": "Start Close",
            "type": "number"
          },
          "symbol": {
            "title": "Symbol",
            "type": "string"
          }
        },
        "required": [
          "symbol",
          "return_pct",
          "start_close",
          "end_close"
        ],
        "title": "ComparisonEntry",
        "type": "object"
      },
      "DailyPrices": {
        "additionalProperties": {
          "additionalProperties": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ]
          },
          "type": "object"
        },
        "type": "object"
      },
      "DocumentIn": {
        "properties": {
          "data": {
            "title": "Data"
          }
        },
        "required": [
          "data"
        ],
        "title": "DocumentIn",
        "type": "object"
      },
      "ExtremeHit": {
        "description": "A symbol trading near its lookback extreme.",
        "properties": {
          "close": {
            "title": "Close",
            "type": "number"
          },
          "distance_pct": {
            "title": "Distance Pct",
            "type": "number"
          },
          "extreme": {
            "title": "Extreme",
            "type": "number"
          },
          "symbol": {
            "title": "Symbol",
            "type": "string"
          }
        },
        "required": [
          "symbol",
          "close",
          "extreme",
          "distance_pct"
        ],
        "title": "ExtremeHit",
        "type": "object"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
