# Agent Controller secrets
# Copy to export-agent-controller.sh, populate, then:
#   source secrets/export-agent-controller.sh

# OpenRouter (for journalist agent, get from openrouter.ai)
export OPENROUTER_API_KEY=""

# Discord (from Discord developer portal)
export DISCORD_BOT_TOKEN=""
export DISCORD_GUILD_ID=""
export DISCORD_LOG_CHANNEL_ID=""  # e.g. 1234567890123456789

# Webhook auth (any random string, used for POST :8080/webhook)
export AI_WEBHOOK_TOKEN=""

# Claude Max OAuth (run: claude setup-token)
export CLAUDE_CODE_OAUTH_TOKEN=""

# GitHub App — PericakAI (from github.com/settings/apps/pericakai)
export GITHUB_APP_ID=""  # e.g. 123456
export GITHUB_APP_PRIVATE_KEY_PATH=""  # path to .pem file
export GITHUB_INSTALL_ID=""  # from github.com/settings/installations URL
